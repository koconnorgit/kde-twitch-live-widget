<?xml version="1.0" encoding="utf-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
                          http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
    <kcfgfile name=""/>
    <group name="General">
        <!-- Optional fallback Client ID. The shipped ID is hardcoded in
             ui/main.qml (embeddedClientId); no settings field exposes this,
             so it normally stays empty. -->
        <entry name="clientId" type="String">
            <default></default>
        </entry>

        <!-- Whitespace/comma separated list of Twitch channel logins to monitor -->
        <entry name="channels" type="String">
            <default></default>
        </entry>

        <!-- Whitespace/comma separated list of Kick channel slugs to monitor -->
        <entry name="kickChannels" type="String">
            <default></default>
        </entry>

        <!-- Seconds between checks -->
        <entry name="pollInterval" type="Int">
            <default>60</default>
        </entry>

        <!-- Pixel size of the streamer name labels -->
        <entry name="fontSize" type="Int">
            <default>14</default>
        </entry>

        <!-- 0 = horizontal expansion, 1 = vertical expansion -->
        <entry name="orientation" type="Int">
            <default>1</default>
        </entry>

        <!-- Empty string = use the current Plasma theme's text color -->
        <entry name="fontColor" type="String">
            <default></default>
        </entry>

        <!-- Empty string = use the default UI font family -->
        <entry name="fontFamily" type="String">
            <default></default>
        </entry>

        <!-- Where the content sits within the (possibly larger) widget box.
             hAlign: 0 = left, 1 = center, 2 = right
             vAlign: 0 = top,  1 = center, 2 = bottom -->
        <entry name="hAlign" type="Int">
            <default>0</default>
        </entry>
        <entry name="vAlign" type="Int">
            <default>0</default>
        </entry>

        <!-- How long (ms) the pointer must dwell before the hover controls
             (refresh/configure) appear. 0 = show immediately. -->
        <entry name="hoverDelay" type="Int">
            <default>800</default>
        </entry>

        <!-- Display-only mirrors of link state, kept in sync by the widget so the
             settings page can show Link vs Unlink without touching the tokens. -->
        <entry name="linked" type="Bool">
            <default>false</default>
        </entry>
        <entry name="kickLinked" type="Bool">
            <default>false</default>
        </entry>

        <!-- Transient command flags: set by the settings Link/Unlink buttons,
             consumed (and reset) by the widget so the form never round-trips
             the live tokens. -->
        <entry name="linkRequested" type="Bool">
            <default>false</default>
        </entry>
        <entry name="unlinkRequested" type="Bool">
            <default>false</default>
        </entry>
        <entry name="kickConnectRequested" type="Bool">
            <default>false</default>
        </entry>
        <entry name="kickDisconnectRequested" type="Bool">
            <default>false</default>
        </entry>

        <!-- Twitch OAuth state from the device code flow (no client secret involved) -->
        <entry name="cachedToken" type="String">
            <default></default>
        </entry>
        <entry name="refreshToken" type="String">
            <default></default>
        </entry>
        <entry name="tokenExpiry" type="Double">
            <default>0</default>
        </entry>

        <!-- Kick OAuth: unlike Twitch, Kick requires a client secret, so each
             user registers their own app at dev.kick.com and enters its
             credentials here. The app access token (client_credentials grant,
             no refresh token) reads only public "who's live" data and is
             re-requested from the credentials whenever it expires. -->
        <entry name="kickClientId" type="String">
            <default></default>
        </entry>
        <entry name="kickClientSecret" type="String">
            <default></default>
        </entry>
        <entry name="kickToken" type="String">
            <default></default>
        </entry>
        <entry name="kickTokenExpiry" type="Double">
            <default>0</default>
        </entry>

        <!-- ============================================================
             Border / background framing (all opt-in; disabled by default
             so the widget stays frameless unless you turn this on).

             Two independent scopes share the same set of knobs:
               widget* → one frame around the whole widget content
               chip*   → a frame around each live-streamer entry

             *CornerStyle: 0 = square, 1 = rounded (radius from *CornerRadius)
             *FillMode:    0 = single color, 1 = gradient, 2 = random
             *FillColors:  comma/space separated hex list; single uses the
                           first, gradient blends all, random picks among them
                           (or a random hue when the list is empty)
             ============================================================ -->

        <!-- Widget-level frame -->
        <entry name="widgetFrameEnabled" type="Bool">
            <default>false</default>
        </entry>
        <entry name="widgetBorderWidth" type="Int">
            <default>1</default>
        </entry>
        <entry name="widgetCornerStyle" type="Int">
            <default>1</default>
        </entry>
        <entry name="widgetCornerRadius" type="Int">
            <default>8</default>
        </entry>
        <entry name="widgetBorderColor" type="String">
            <default></default>
        </entry>
        <entry name="widgetFillOpacity" type="Double">
            <default>0.35</default>
        </entry>
        <entry name="widgetFillMode" type="Int">
            <default>0</default>
        </entry>
        <entry name="widgetFillColors" type="String">
            <default></default>
        </entry>

        <!-- Per-streamer chip frame -->
        <entry name="chipFrameEnabled" type="Bool">
            <default>false</default>
        </entry>
        <entry name="chipBorderWidth" type="Int">
            <default>1</default>
        </entry>
        <entry name="chipCornerStyle" type="Int">
            <default>1</default>
        </entry>
        <entry name="chipCornerRadius" type="Int">
            <default>8</default>
        </entry>
        <entry name="chipBorderColor" type="String">
            <default></default>
        </entry>
        <entry name="chipFillOpacity" type="Double">
            <default>0.35</default>
        </entry>
        <entry name="chipFillMode" type="Int">
            <default>0</default>
        </entry>
        <entry name="chipFillColors" type="String">
            <default></default>
        </entry>
    </group>
</kcfg>
